const FlujoProgress = ({ icon: Icon, label, actual, previsto, chartColor, sub, isLast }) => {
  const ratio = previsto > 0 ? Math.min(actual / previsto, 1.15) : 0;
  const pctNum = previsto > 0 ? (actual / previsto * 100) : 0;

  return (
