<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ATLAS · Tesorería · Vista general · Fase B</title>
<style>
  /* ─── tokens v4/v5 ─── */
  :root {
    --bg-page: #faf8f3;
    --bg-card: #ffffff;
    --bg-soft: #f5f1e8;
    --bg-hover: #f0ebde;
    --bg-selected: #fdf4dc;
    --bg-navy: #0a1f3d;
    --bg-navy-soft: #14294f;
    --txt-navy: #0a1f3d;
    --txt-default: #1a1a1a;
    --txt-muted: #6b7280;
    --txt-on-navy: #f5f1e8;
    --txt-on-navy-muted: #aab3c4;
    --gold: #c8a04a;
    --gold-soft: #e0c479;
    --teal: #0d6868;
    --amber-bg: #fef4e0;
    --amber-text: #8a5a00;
    --amber-border: #f5d99e;
    --red-bg: #fce8e6;
    --red-text: #8a2422;
    --red-border: #f0b3ad;
    --border: #e5dfd0;
    --border-strong: #d4cdb8;
    --shadow-card: 0 1px 2px rgba(10,31,61,0.04), 0 4px 12px rgba(10,31,61,0.04);
    --shadow-drawer: -4px 0 24px rgba(10,31,61,0.12);
    --radius-sm: 6px;
    --radius-md: 10px;
    --radius-lg: 14px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { font-family: 'Inter', -apple-system, sans-serif; background: var(--bg-page); color: var(--txt-default); font-size: 14px; line-height: 1.5; min-height: 100vh; width: 100%; max-width: 100%; overflow-x: hidden; }
  .mono { font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace; font-variant-numeric: tabular-nums; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; }
  input { font-family: inherit; }

  /* ─── layout · ocupa todo el ancho ─── */
  .app { display: grid; grid-template-columns: 240px 1fr; min-height: 100vh; width: 100%; max-width: 100%; }
  .main { display: flex; flex-direction: column; min-width: 0; width: 100%; }
  .sidebar { background: var(--bg-navy); color: var(--txt-on-navy); padding: 20px 0; position: sticky; top: 0; height: 100vh; overflow-y: auto; }
  .brand { padding: 8px 20px 24px; display: flex; align-items: center; gap: 12px; }
  .brand-mark { width: 36px; height: 36px; background: var(--gold); color: var(--bg-navy); display: grid; place-items: center; border-radius: var(--radius-sm); font-weight: 800; font-size: 16px; }
  .brand-name { font-weight: 700; font-size: 15px; letter-spacing: 0.5px; }
  .brand-sub { font-size: 10px; color: var(--txt-on-navy-muted); letter-spacing: 1.5px; text-transform: uppercase; margin-top: 2px; }
  .nav-section { padding: 16px 0 8px; }
  .nav-label { padding: 0 20px 8px; font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--txt-on-navy-muted); }
  .nav-item { padding: 10px 20px; color: var(--txt-on-navy-muted); display: flex; align-items: center; gap: 12px; cursor: pointer; transition: all 0.15s; border-left: 3px solid transparent; }
  .nav-item:hover { color: var(--txt-on-navy); background: var(--bg-navy-soft); }
  .nav-item.active { color: var(--txt-on-navy); border-left-color: var(--gold); background: var(--bg-navy-soft); }
  .nav-icon { width: 18px; height: 18px; flex-shrink: 0; }

  /* ─── topbar SIN buscador (excepto Panel) ─── */
  .topbar { background: var(--bg-card); border-bottom: 1px solid var(--border); padding: 12px 32px; display: flex; align-items: center; justify-content: flex-end; gap: 8px; position: sticky; top: 0; z-index: 10; }
  .icon-btn { width: 36px; height: 36px; border-radius: var(--radius-sm); display: grid; place-items: center; color: var(--txt-muted); position: relative; }
  .icon-btn:hover { background: var(--bg-soft); color: var(--txt-navy); }
  .badge { position: absolute; top: 4px; right: 4px; background: var(--gold); color: var(--bg-navy); font-size: 9px; font-weight: 700; min-width: 16px; height: 16px; border-radius: 8px; display: grid; place-items: center; padding: 0 4px; }

  /* ─── BANNER NAVY · MI TESORERÍA · estilo Inversiones ─── */
  .banner-navy { background: var(--bg-navy); color: var(--txt-on-navy); padding: 24px 32px 28px; }
  .banner-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr 1fr; gap: 20px; align-items: end; }
  .banner-section-title { display: flex; align-items: center; gap: 10px; }
  .banner-section-title .gold-dot { width: 6px; height: 6px; background: var(--gold); border-radius: 50%; }
  .banner-section-title h2 { font-size: 13px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--txt-on-navy); }
  .kpi-banner { padding-left: 20px; border-left: 1px solid rgba(255,255,255,0.08); }
  .kpi-banner .label { font-size: 10px; color: var(--txt-on-navy-muted); letter-spacing: 1.2px; text-transform: uppercase; margin-bottom: 6px; font-weight: 600; }
  .kpi-banner .value { font-family: 'JetBrains Mono', monospace; font-size: 24px; font-weight: 700; letter-spacing: -0.5px; line-height: 1; }
  .kpi-banner .sub { font-size: 11px; color: var(--txt-on-navy-muted); margin-top: 6px; }
  .pos { color: #6ee7c5; }
  .neg { color: #ff8b8b; }

  /* ─── subcabecera blanca ─── */
  .subheader { background: var(--bg-card); padding: 24px 32px 16px; display: flex; align-items: flex-start; justify-content: space-between; gap: 24px; }
  .subheader h1 { font-size: 26px; font-weight: 700; color: var(--txt-navy); letter-spacing: -0.4px; line-height: 1.2; }
  .subheader-sub { color: var(--txt-muted); font-size: 13px; margin-top: 4px; }
  .subheader-sub a { color: var(--gold); text-decoration: none; font-weight: 500; }
  .subheader-sub a:hover { text-decoration: underline; }
  .subheader-actions { display: flex; gap: 8px; }
  .btn { padding: 9px 16px; border-radius: var(--radius-sm); font-size: 13px; font-weight: 500; display: inline-flex; align-items: center; gap: 6px; transition: all 0.15s; }
  .btn-primary { background: var(--gold); color: var(--bg-navy); }
  .btn-primary:hover { background: var(--gold-soft); }
  .btn-ghost { color: var(--txt-navy); border: 1px solid var(--border-strong); background: var(--bg-card); }
  .btn-ghost:hover { background: var(--bg-soft); }
  .btn-ghost-light { color: var(--txt-on-navy); border: 1px solid rgba(255,255,255,0.2); background: transparent; }
  .btn-ghost-light:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.35); }

  /* ─── tabs ─── */
  .tabs-bar { background: var(--bg-card); border-bottom: 1px solid var(--border); padding: 0 32px; display: flex; gap: 0; }
  .tab { padding: 14px 20px; font-size: 13px; font-weight: 500; color: var(--txt-muted); border-bottom: 2px solid transparent; transition: all 0.15s; }
  .tab:hover { color: var(--txt-navy); }
  .tab.active { color: var(--txt-navy); font-weight: 600; border-bottom-color: var(--gold); }
  .tab-count { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--txt-muted); margin-left: 6px; background: var(--bg-soft); padding: 1px 6px; border-radius: 8px; }

  /* ─── content ─── */
  .content { padding: 24px 32px 60px; }
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .section-title { font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--txt-muted); font-weight: 700; }
  .section-meta { font-size: 11px; color: var(--txt-muted); display: flex; align-items: center; gap: 10px; }
  .section-meta-arrow { width: 28px; height: 28px; border-radius: 4px; display: grid; place-items: center; color: var(--txt-muted); border: 1px solid var(--border); cursor: pointer; }
  .section-meta-arrow:hover { background: var(--bg-soft); color: var(--txt-navy); }

  /* ─── carrusel cuentas ─── */
  .accounts-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 32px; }
  .account-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 18px; box-shadow: var(--shadow-card); cursor: pointer; transition: all 0.15s; position: relative; }
  .account-card:hover { border-color: var(--border-strong); transform: translateY(-1px); box-shadow: 0 4px 16px rgba(10,31,61,0.06); }
  .account-card-top { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 14px; }
  .account-id { display: flex; align-items: center; gap: 10px; min-width: 0; }
  .bank-logo-sm { width: 36px; height: 36px; border-radius: var(--radius-sm); display: grid; place-items: center; font-weight: 800; font-size: 14px; color: white; flex-shrink: 0; }
  .bank-logo-sm.santander { background: linear-gradient(135deg, #ec0000, #c00000); }
  .bank-logo-sm.bbva { background: linear-gradient(135deg, #1973b8, #0a5796); }
  .bank-logo-sm.unicaja { background: linear-gradient(135deg, #0a1f3d, #14294f); }
  .bank-logo-sm.sabadell { background: linear-gradient(135deg, #1e6dd0, #134d99); }
  .bank-logo-sm.ing { background: linear-gradient(135deg, #ff6200, #d65300); }
  .account-name { font-weight: 600; color: var(--txt-navy); font-size: 14px; }
  .account-iban { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--txt-muted); margin-top: 2px; }
  .edit-btn { width: 28px; height: 28px; border-radius: 4px; color: var(--txt-muted); display: grid; place-items: center; }
  .edit-btn:hover { background: var(--bg-soft); color: var(--txt-navy); }
  .account-balance { font-family: 'JetBrains Mono', monospace; font-size: 26px; font-weight: 700; color: var(--txt-navy); letter-spacing: -0.5px; margin-bottom: 14px; }
  .account-state { padding-top: 12px; border-top: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
  .state-pill { padding: 3px 10px; border-radius: 12px; font-size: 11px; font-weight: 600; }
  .state-pendiente { background: var(--amber-bg); color: var(--amber-text); border: 1px solid var(--amber-border); }
  .state-aldia { background: var(--bg-soft); color: var(--txt-muted); border: 1px solid var(--border); }
  .state-count { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--txt-muted); }

  /* ─── calendario ─── */
  .calendar-section { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 24px; box-shadow: var(--shadow-card); }
  .calendar-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 20px; gap: 24px; }
  .calendar-title h3 { font-size: 16px; font-weight: 700; color: var(--txt-navy); }
  .calendar-subtitle { font-size: 12px; color: var(--txt-muted); margin-top: 4px; }
  .calendar-meta { display: flex; align-items: center; gap: 16px; }
  .calendar-summary { text-align: right; }
  .calendar-summary .lbl { font-size: 10px; color: var(--txt-muted); letter-spacing: 1.2px; text-transform: uppercase; font-weight: 600; }
  .calendar-summary .val { font-family: 'JetBrains Mono', monospace; font-size: 16px; font-weight: 700; color: var(--txt-navy); margin-top: 2px; }
  .calendar-nav { display: flex; gap: 4px; }
  .calendar-nav-btn { width: 32px; height: 32px; border-radius: 4px; border: 1px solid var(--border); color: var(--txt-muted); display: grid; place-items: center; }
  .calendar-nav-btn:hover { background: var(--bg-soft); color: var(--txt-navy); }

  /* grid 12 meses */
  .calendar-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
  .month-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 14px 16px; cursor: pointer; transition: all 0.15s; position: relative; }
  .month-card:hover { border-color: var(--border-strong); background: var(--bg-hover); }
  .month-card.current { border: 2px solid var(--gold); background: var(--bg-selected); padding: 13px 15px; }
  .month-card.problem::before { content: ""; position: absolute; left: -1px; top: -1px; bottom: -1px; width: 3px; background: var(--amber-text); border-radius: var(--radius-sm) 0 0 var(--radius-sm); }
  .month-name-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .month-name { font-weight: 700; color: var(--txt-navy); font-size: 14px; }
  .month-name.current-name { color: var(--txt-navy); }
  .pill-curso { background: var(--gold); color: var(--bg-navy); padding: 2px 7px; border-radius: 8px; font-size: 9px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; }
  .month-row { display: grid; grid-template-columns: auto 1fr; gap: 8px; align-items: baseline; padding: 4px 0; }
  .month-row .lbl { font-size: 10px; color: var(--txt-muted); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500; }
  .month-row .val { font-family: 'JetBrains Mono', monospace; font-size: 16px; font-weight: 700; color: var(--txt-navy); text-align: right; letter-spacing: -0.3px; }
  .month-row.primary .val { font-size: 19px; }
  .month-row.secondary .val { font-size: 13px; color: var(--txt-default); font-weight: 600; }
  .month-row.muted .val { font-size: 12px; color: var(--txt-muted); font-weight: 500; }
  .month-row .val.in { color: var(--txt-navy); }
  .month-row .val.out { color: var(--teal); }
  .month-divider { border-top: 1px dashed var(--border); margin: 8px 0; }
  .month-pendientes { padding-top: 6px; }
  .month-row-mini { display: flex; align-items: center; justify-content: space-between; font-size: 11px; padding: 2px 0; }
  .month-row-mini .lbl { color: var(--txt-muted); }
  .month-row-mini .val { font-family: 'JetBrains Mono', monospace; font-weight: 600; }
  .month-row-mini .val.in { color: var(--txt-navy); }
  .month-row-mini .val.out { color: var(--teal); }
  .month-problem-tag { margin-top: 6px; font-size: 10px; color: var(--amber-text); background: var(--amber-bg); padding: 3px 6px; border-radius: 4px; display: inline-flex; align-items: center; gap: 4px; }

  /* ─── DRAWERS ─── */
  .drawer-overlay { position: fixed; inset: 0; background: rgba(10,31,61,0.3); z-index: 50; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
  .drawer { position: fixed; top: 0; right: 0; height: 100vh; width: 540px; background: var(--bg-card); box-shadow: var(--shadow-drawer); z-index: 51; transform: translateX(100%); transition: transform 0.2s; display: flex; flex-direction: column; }
  .drawer-overlay.show { opacity: 1; pointer-events: auto; }
  .drawer.show { transform: translateX(0); }
  .drawer-header { padding: 20px 24px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
  .drawer-back-close { display: flex; gap: 8px; align-items: center; }
  .drawer-back-btn, .drawer-close-btn { width: 32px; height: 32px; border-radius: 4px; color: var(--txt-muted); display: grid; place-items: center; border: 1px solid var(--border); }
  .drawer-back-btn:hover, .drawer-close-btn:hover { background: var(--bg-soft); color: var(--txt-navy); }
  .drawer-title { font-size: 18px; font-weight: 700; color: var(--txt-navy); }
  .drawer-sub { font-size: 12px; color: var(--txt-muted); margin-top: 2px; }
  .drawer-body { flex: 1; overflow-y: auto; padding: 20px 24px; }
  .drawer-kpi-row { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; padding: 14px 16px; background: var(--bg-soft); border-radius: var(--radius-sm); margin-bottom: 20px; }
  .drawer-kpi { }
  .drawer-kpi .lbl { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: var(--txt-muted); font-weight: 700; margin-bottom: 4px; }
  .drawer-kpi .val { font-family: 'JetBrains Mono', monospace; font-size: 16px; font-weight: 700; }
  .drawer-kpi .val.in { color: var(--txt-navy); }
  .drawer-kpi .val.out { color: var(--teal); }

  /* mini calendario grid días en drawer mes */
  .mini-grid-section { margin-bottom: 24px; }
  .mini-grid-title { font-size: 10px; letter-spacing: 1.2px; text-transform: uppercase; color: var(--txt-muted); font-weight: 700; margin-bottom: 12px; }
  .mini-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 4px; }
  .mini-grid-head { font-size: 10px; color: var(--txt-muted); text-align: center; padding: 4px; font-weight: 600; }
  .mini-day { background: var(--bg-card); border: 1px solid var(--border); border-radius: 4px; padding: 8px 6px; min-height: 56px; cursor: pointer; transition: all 0.12s; position: relative; display: flex; flex-direction: column; }
  .mini-day:hover { border-color: var(--gold); }
  .mini-day.empty { background: transparent; border-color: transparent; cursor: default; }
  .mini-day-num { font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 600; color: var(--txt-default); }
  .mini-day-total { font-family: 'JetBrains Mono', monospace; font-size: 10px; margin-top: auto; font-weight: 600; }
  .mini-day-total.in { color: var(--txt-navy); }
  .mini-day-total.out { color: var(--teal); }
  .mini-day-mark { position: absolute; top: 6px; right: 6px; width: 6px; height: 6px; border-radius: 50%; }
  .mini-day-mark.confirmed { background: var(--txt-navy); }
  .mini-day-mark.pending { background: var(--gold); }
  .mini-day.today { border-color: var(--gold); border-width: 2px; padding: 7px 5px; }

  /* secciones colapsables drawer mes */
  .collapsible { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-sm); margin-bottom: 12px; overflow: hidden; }
  .collapsible-header { padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; cursor: pointer; }
  .collapsible-header:hover { background: var(--bg-hover); }
  .collapsible-title { display: flex; align-items: center; gap: 10px; }
  .collapsible-arrow { color: var(--txt-muted); transition: transform 0.15s; }
  .collapsible.open .collapsible-arrow { transform: rotate(90deg); }
  .collapsible-name { font-size: 12px; font-weight: 600; color: var(--txt-navy); letter-spacing: 0.3px; text-transform: uppercase; }
  .collapsible-counter { font-size: 11px; color: var(--txt-muted); font-weight: 500; }
  .collapsible-amount { font-family: 'JetBrains Mono', monospace; font-weight: 700; }
  .collapsible-amount.in { color: var(--txt-navy); }
  .collapsible-amount.out { color: var(--teal); }
  .collapsible-body { display: none; padding: 0 16px 12px; }
  .collapsible.open .collapsible-body { display: block; }
  .item-row { padding: 10px 12px; display: grid; grid-template-columns: 14px 1fr auto auto; gap: 10px; align-items: center; border-radius: 4px; font-size: 13px; }
  .item-row:hover { background: var(--bg-soft); }
  .item-mark { width: 14px; height: 14px; border-radius: 50%; display: grid; place-items: center; }
  .item-mark.confirmed { background: var(--txt-navy); color: white; }
  .item-mark.pending { background: var(--gold); color: var(--bg-navy); }
  .item-mark svg { width: 10px; height: 10px; }
  .item-concept { font-size: 13px; color: var(--txt-default); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .item-meta { font-size: 11px; color: var(--txt-muted); margin-top: 2px; }
  .item-date { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--txt-muted); white-space: nowrap; }
  .item-amount { font-family: 'JetBrains Mono', monospace; font-weight: 700; font-size: 13px; text-align: right; }
  .item-amount.in { color: var(--txt-navy); }
  .item-amount.out { color: var(--teal); }

  /* drawer día · banco protagonista */
  .bank-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md); margin-bottom: 12px; overflow: hidden; }
  .bank-card-head { padding: 14px 16px; display: flex; align-items: center; gap: 12px; }
  .bank-card-id { flex: 1; min-width: 0; }
  .bank-card-name { font-weight: 700; font-size: 14px; color: var(--txt-navy); }
  .bank-card-iban { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--txt-muted); margin-top: 2px; }
  .bank-card-balance { display: flex; align-items: baseline; gap: 8px; font-family: 'JetBrains Mono', monospace; font-size: 13px; }
  .bank-balance-arrow { color: var(--txt-muted); font-size: 11px; }
  .bank-balance-end { font-weight: 700; color: var(--txt-navy); }
  .bank-balance-end.problem { color: var(--red-text); }
  .bank-card-movs { padding: 0 16px 14px; }
  .bank-card-movs-header { padding: 10px 0 8px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--border); margin-bottom: 4px; }
  .bank-card-movs-title { font-size: 10px; letter-spacing: 1px; text-transform: uppercase; color: var(--txt-muted); font-weight: 700; }
  .bank-card-movs-total { font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 700; }
  .bank-card-movs-total.in { color: var(--txt-navy); }
  .bank-card-movs-total.out { color: var(--teal); }
  .bank-card-actions { display: flex; gap: 6px; padding: 10px 16px 14px; border-top: 1px solid var(--border); }
  .bank-card-action { flex: 1; padding: 8px 12px; font-size: 12px; font-weight: 500; border-radius: 4px; border: 1px solid var(--border); color: var(--txt-navy); }
  .bank-card-action:hover { background: var(--bg-soft); }
  .bank-card-action.primary { background: var(--gold); color: var(--bg-navy); border-color: var(--gold); font-weight: 600; }
  .bank-card-action.primary:hover { background: var(--gold-soft); }
  .bank-empty { padding: 14px 16px; font-size: 12px; color: var(--txt-muted); border-top: 1px solid var(--border); }

