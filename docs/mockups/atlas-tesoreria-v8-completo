<script>
  function openMonthDrawer() {
    document.getElementById('monthOverlay').classList.add('show');
    document.getElementById('monthDrawer').classList.add('show');
  }
  function closeMonthDrawer() {
    document.getElementById('monthOverlay').classList.remove('show');
    document.getElementById('monthDrawer').classList.remove('show');
  }
  function openDayDrawer() {
    document.getElementById('dayOverlay').classList.add('show');
    document.getElementById('dayDrawer').classList.add('show');
  }
  function closeDayDrawer() {
    document.getElementById('dayOverlay').classList.remove('show');
    document.getElementById('dayDrawer').classList.remove('show');
  }
  function openMovDrawer() {
    document.getElementById('movOverlay').classList.add('show');
    document.getElementById('movDrawer').classList.add('show');
  }
  function closeMovDrawer() {
    document.getElementById('movOverlay').classList.remove('show');
    document.getElementById('movDrawer').classList.remove('show');
  }
  function toggleColl(id) {
    document.getElementById(id).classList.toggle('open');
  }

  // navegación vista general ↔ vista cuenta
  function openAccount(name) {
    document.body.classList.add('show-account');
    window.scrollTo(0, 0);
    // (en app real · aquí se cargan datos según la cuenta)
  }
  function closeAccount() {
    document.body.classList.remove('show-account');
    window.scrollTo(0, 0);
  }

  // bulk vista cuenta
  function updateAcctBulk() {
    const checked = document.querySelectorAll('.vista-cuenta .mov-list-row input[type="checkbox"]:checked');
    const bar = document.getElementById('acctBulkBar');
    if (checked.length > 0) {
      bar.classList.remove('hidden');
      document.getElementById('acctBulkCount').textContent = checked.length;
    } else {
      bar.classList.add('hidden');
    }
    document.querySelectorAll('.vista-cuenta .mov-list-row').forEach(r => {
      const cb = r.querySelector('input[type="checkbox"]');
      r.classList.toggle('selected', cb && cb.checked);
    });
  }
  function toggleAllAcctRows(master) {
    document.querySelectorAll('.vista-cuenta .mov-list-row input[type="checkbox"]').forEach(cb => cb.checked = master.checked);
    updateAcctBulk();
  }

  // chips temporal vista cuenta
  document.querySelectorAll('.vista-cuenta .chip-group .chip').forEach(c => c.addEventListener('click', () => {
    document.querySelectorAll('.vista-cuenta .chip-group .chip').forEach(x => x.classList.remove('active'));
    c.classList.add('active');
  }));
  // pills estado vista cuenta
  document.querySelectorAll('.vista-cuenta .pill-group .pill').forEach(p => p.addEventListener('click', () => {
    document.querySelectorAll('.vista-cuenta .pill-group .pill').forEach(x => x.classList.remove('active'));
    p.classList.add('active');
  }));
</script>
